{
  "name": "wv-vue3-ui",
  "version": "0.1.0",
  "description": "WuWei Design System - 无为设计系统 Vue 3 组件库",
  "author": "wuwei",
  "license": "MIT",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "vue3",
    "vue",
    "tailwindcss",
    "components",
    "design-system",
    "ui",
    "wuwei-design",
    "wv-vue3-ui"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:cherishtong/wv-vue3-ui.git"
  },
  "bugs": {
    "url": "https://github.com/cherishtong/wv-vue3-ui/issues"
  },
  "homepage": "https://cherishtong.github.io/wv-vue3-ui/",
  "scripts": {
    "dev": "vp dev",
    "build": "npx --yes vite@8 build",
    "build:ci": "vite build",
    "pack": "vite build --config vite.lib.config.ts",
    "preview": "vp preview",
    "prepare": "vp config"
  },
  "peerDependencies": {
    "vue": ">=3.4.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.5.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.8",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vue": "^3.5.33"
  },
  "packageManager": "pnpm@10.33.2"
}
